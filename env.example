# Backend Environment Configuration
# Copy this file to .env and update the values for production

# HuggingFace API Key (REQUIRED for embeddings)
# Get your free token at: https://huggingface.co/settings/tokens
# Free tier: 1,000 requests/month
HF_API_KEY=your_huggingface_token_here

# CORS Origins - comma-separated list of allowed origins
# For production with Vercel frontend:
# CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main-username.vercel.app

# For development (allow all):
CORS_ORIGINS=*

# Optional: Use local embeddings instead of API (fallback for development)
# Set to 'true' if you want to use local sentence-transformers instead of API
# This requires ~400MB model download and more RAM
USE_LOCAL_EMBEDDINGS=false
